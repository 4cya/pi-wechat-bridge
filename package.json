    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx tsx src/index.ts"
  },
  "keywords": [
    "pi-agent",
    "wechat",
    "weixin",
    "微信",
    "bridge",
    "ai-agent",
    "coding-agent",
    "multi-session",
    "chatbot",
    "ai-chat",
    "session-router",
    "terminal",
    "cli",
    "pi-package"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/4cya/pi-wechat-bridge.git"
  },
  "dependencies": {
    "@wechatbot/wechatbot": "^2.0.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  }
}
